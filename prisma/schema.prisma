generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id       String  @id @default(uuid())
    email    String  @unique
    password String
    phone    String?
    fullname String
    bio      String?
    avatar   String?

    refreshToken   String?
    emailVeriified Boolean @default(false)
}
